# ═══════════════════════════════════════════════════════════════
# FacturaCL — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a git.
# ═══════════════════════════════════════════════════════════════

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Koywe API ─────────────────────────────────────────────────
# URL base de la API (sandbox o producción)
KOYWE_BASE_URL=https://api-billing.koywe.com

# Timeout en ms para llamadas a Koywe (default: 15000)
KOYWE_TIMEOUT_MS=15000

# Credenciales de acceso (sandbox demo)
KOYWE_CLIENT_ID=demo/001
KOYWE_CLIENT_SECRET=ad258748356c5104df2bf4bdbabd3352
KOYWE_USERNAME=1.111.111-1/demoapi
KOYWE_PASSWORD=76be37bcc4970d29e519fca46edead19
KOYWE_ACCOUNT_ID=423

# ── Emisor (datos del negocio) ────────────────────────────────
ISSUER_RUT=76399932-7
ISSUER_LEGAL_NAME=Empresa Demo Chile SpA
ISSUER_ACTIVITY=Comidas rápidas y bebidas
ISSUER_ADDRESS=Av. Libertador 1234, Santiago Centro
ISSUER_DISTRICT=Santiago
ISSUER_CITY=Santiago
ISSUER_COUNTRY_ID=253

# ── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos separados por coma.
# En desarrollo: http://localhost:5173
# En producción: tu dominio real
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Integración QuickPOS ──────────────────────────────────────
# API key que QuickPOS usa para llamar a /api/pos/*
# Genera un string aleatorio seguro: openssl rand -hex 32
QUICKPOS_API_KEY=cambia_esto_por_un_api_key_seguro

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_DOCS_MAX=20

# ── Logs ──────────────────────────────────────────────────────
# Niveles: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# En desarrollo usar "pretty", en producción dejar vacío para JSON
LOG_PRETTY=true
