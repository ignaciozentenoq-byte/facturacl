{
  "name": "facturacl",
  "version": "2.0.0",
  "description": "FacturaCL — Módulo de facturación electrónica vía Koywe. Embebible en QuickPOS.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev":         "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server":  "node --watch --env-file=.env server/index.js",
    "dev:client":  "vite",
    "build":       "vite build",
    "start":       "NODE_ENV=production node server/index.js",
    "test":        "vitest run",
    "test:watch":  "vitest",
    "test:coverage":"vitest run --coverage",
    "lint":        "eslint . --ext .js",
    "docker:build":"docker build -t facturacl .",
    "docker:run":  "docker run --env-file .env -p 3000:3000 facturacl"
  },
  "dependencies": {
    "compression":        "^1.7.4",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":             "^7.1.0",
    "pino":               "^9.3.1",
    "pino-pretty":        "^11.2.1",
    "zod":                "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently":        "^8.2.2",
    "eslint":              "^9.6.0",
    "supertest":           "^7.0.0",
    "vite":                "^5.3.3",
    "vitest":              "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
